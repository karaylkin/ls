{
  "name": "lockstock",
  "version": "1.0.0",
  "description": "Числовой покер — многопользовательская онлайн-игра (угадай число + покерные ставки)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "serve": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test src/game/sidepots.test.ts"
  },
  "dependencies": {
    "express": "^4.19.2",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
